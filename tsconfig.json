{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["chrome"],
    "isolatedModules": true
  },
  "include": ["src", "tests/unit"],
  "exclude": ["node_modules", "dist"]
}
